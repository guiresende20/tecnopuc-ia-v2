# ============================================================
# TecnoPUC Chatbot — Exemplo de variáveis de ambiente
# ============================================================
# Copie este arquivo para .env.local (dev) e preencha com valores reais.
# Em produção (Netlify), configure no painel: Site settings → Environment variables.
# ============================================================

# --- GEMINI ---
# Chave privada da API Gemini. APENAS server-side — nunca exposta ao browser.
# Criar em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# --- SUPABASE ---
# URL do projeto Supabase
SUPABASE_URL=

# Chave service_role (bypassa RLS). APENAS server-side.
# Dashboard do Supabase → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=

# --- SEGURANÇA ---
# Token Bearer para proteger POST /api/ingest (reindexação via HTTP).
# Gere um valor aleatório: openssl rand -hex 32
INGEST_SECRET=

# --- CREDENCIAIS PAINEL ADMIN ---
# Login único (formato legado)
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Ou múltiplos admins (JSON, tem precedência sobre os dois acima)
# ADMIN_USERS=[{"username":"fulano","password":"senha1"},{"username":"ciclano","password":"senha2"}]

# --- RATE LIMITING (Upstash Redis) ---
# Criar banco Redis gratuito em: https://console.upstash.com/redis
# Se ambas vazias, rate limit vira no-op (útil em dev; obrigatório em prod).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- GOOGLE ANALYTICS 4 ---
# Measurement ID da propriedade GA4 (formato G-XXXXXXXXXX).
# Criar em: https://analytics.google.com → Admin → Data streams → Web
# Public por design (vai pro browser). GA4 só carrega após consentimento LGPD.
NEXT_PUBLIC_GA_ID=
